---
// Testimonios.astro

const testimonios = [
  {
    id: "luis",
    nombre: "Luis Rodríguez",
    negocio: "Despensa DIBU",
    ubicacion: "Aguilares, Tucumán",
    rubro: "Despensa",
    texto: "Todo llegó perfecto. Ya está todo cargado en la PC, todo listo.",
    detalle: "Software + Equipamiento completo (Mini PC+Tickeadora+Scanner) · Envío a Tucumán",
    icono: "🛒",
    remoto: true,
    imagenes: [
      "/images/testimonios/luis-1.jpg",
      "/images/testimonios/luis-2.jpg",
      "/images/testimonios/luis-3.jpg",
    ],
  },
  {
    id: "hector",
    nombre: "Héctor Leschinsky",
    negocio: "La Esquina del Descartable",
    ubicacion: "Catamarca Capital, Catamarca",
    rubro: "Descartables por Mayor y Menor",
    texto: "Gracias a ustedes. Recién termino de armar la máquina y ya está funcionando.",
    detalle: "Software completo · Instalación 100% remota",
    icono: "📦",
    remoto: true,
    imagenes: [
      "/images/testimonios/hector-1.jpg",
      "/images/testimonios/hector-2.jpg",
      "/images/testimonios/hector-3.jpg",
    ],
  },
  {
    id: "luciana",
    nombre: "Luciana Quiroga",
    negocio: "El Shop",
    ubicacion: "Oliva, Córdoba",
    rubro: "Mini Super / Drugstore",
    texto: "Estamos cargando productos... ¡es una locura la cantidad de cosas que hay! Lucas, te mando otro cliente.",
    detalle: "Software + Balanzas digitales · Soporte remoto",
    icono: "🏪",
    remoto: true,
    imagenes: [
      "/images/testimonios/luciana-1.jpg",
      "/images/testimonios/luciana-2.jpg",
      "/images/testimonios/luciana-3.jpg",
    ],
  },
  {
    id: "martin",
    nombre: "Martín Zárate",
    negocio: "La Chilena",
    ubicacion: "Córdoba Capital",
    rubro: "Supermercado y Distribuidora",
    texto: "Está bueno para tenerlo en cuenta. Dale Lucas.",
    detalle: "Sistema completo · 2 sucursales · Red de datos · Paneles solares",
    icono: "🏬",
    remoto: false,
    imagenes: [
      "/images/testimonios/martin-1.jpg",
      "/images/testimonios/martin-2.jpg",
      "/images/testimonios/martin-3.jpg",
    ],
  },
];
---

<section id="testimonios" class="bg-brand-dark py-20 px-4">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="text-brand-blue text-sm font-semibold uppercase tracking-widest">Testimonios</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-brand-text mt-2">
        Lo que dicen nuestros clientes
      </h2>
      <p class="text-brand-muted mt-4 max-w-xl mx-auto">
        Comercios de todo el país confían en Lugic Systems. Estas son sus palabras, directo del WhatsApp.
      </p>
    </div>

    <!-- Grid de cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {testimonios.map((t) => (
        <div class="bg-brand-mid border border-brand-border rounded-2xl p-6 flex flex-col gap-4 hover:border-brand-blue transition-colors duration-300">

          <!-- Cita -->
          <div class="relative">
            <span class="text-brand-blue text-4xl leading-none font-serif absolute -top-2 -left-1 select-none">"</span>
            <p class="text-brand-text text-base leading-relaxed pl-6 italic">
              {t.texto}
            </p>
          </div>

          <!-- Divider -->
          <div class="border-t border-brand-border"></div>

          <!-- Info del cliente -->
          <div class="flex items-start gap-3">
            <div class="text-3xl leading-none mt-0.5">{t.icono}</div>
            <div class="flex-1 min-w-0">
              <p class="text-brand-text font-semibold">{t.nombre}</p>
              <p class="text-brand-blue text-sm font-medium">{t.negocio}</p>
              <p class="text-brand-muted text-sm">{t.rubro} · {t.ubicacion}</p>
            </div>
            <!-- Badge remoto/presencial -->
            <div class="shrink-0">
              {t.remoto ? (
                <span class="text-xs px-2 py-1 rounded-full bg-brand-blue/10 text-brand-blue border border-brand-blue/20 whitespace-nowrap">
                  🌐 Remoto
                </span>
              ) : (
                <span class="text-xs px-2 py-1 rounded-full bg-green-500/10 text-green-400 border border-green-500/20 whitespace-nowrap">
                  📍 Presencial
                </span>
              )}
            </div>
          </div>

          <!-- Detalle + botón ver conversación -->
          <div class="flex items-center justify-between border-t border-brand-border pt-3 gap-3">
            <p class="text-brand-muted text-xs flex-1">{t.detalle}</p>
            <button
              class="lightbox-trigger shrink-0 text-xs px-3 py-1.5 rounded-lg bg-brand-blue/10 text-brand-blue border border-brand-blue/20 hover:bg-brand-blue/20 transition-colors whitespace-nowrap"
              data-imagenes={JSON.stringify(t.imagenes)}
            >
              Ver conversación REAL →
            </button>
          </div>

        </div>
      ))}
    </div>

    <!-- Cobertura nacional -->
    <div class="mt-12 text-center">
      <p class="text-brand-muted text-sm">
        Clientes activos en todo el país.
        <a href="#contacto" class="text-brand-blue hover:underline ml-1">Sumá tu negocio →</a>
      </p>
    </div>

  </div>
</section>

<!-- Lightbox -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 backdrop-blur-sm p-4"
  role="dialog"
  aria-modal="true"
  aria-label="Conversación de WhatsApp"
>
  <!-- Overlay para cerrar -->
  <div id="lightbox-overlay" class="absolute inset-0"></div>

  <!-- Contenedor -->
  <div class="relative z-10 flex flex-col items-center gap-4 w-full max-w-sm">

    <!-- Cerrar -->
    <button
      id="lightbox-close"
      class="absolute -top-2 -right-2 w-9 h-9 rounded-full bg-brand-mid border border-brand-border text-brand-muted hover:text-brand-text hover:border-brand-blue transition-colors flex items-center justify-center text-lg z-20"
      aria-label="Cerrar"
    >
      ✕
    </button>

    <!-- Imagen -->
    <div class="relative w-full">
      <img
        id="lightbox-img"
        src=""
        alt="Conversación de WhatsApp"
        class="w-full max-h-[75vh] object-contain rounded-xl shadow-2xl"
      />

      <!-- Prev -->
      <button
        id="lightbox-prev"
        class="absolute left-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-black/60 border border-white/10 text-white hover:bg-brand-blue/70 transition-colors items-center justify-center text-xl hidden"
        aria-label="Anterior"
      >‹</button>

      <!-- Next -->
      <button
        id="lightbox-next"
        class="absolute right-2 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-black/60 border border-white/10 text-white hover:bg-brand-blue/70 transition-colors items-center justify-center text-xl hidden"
        aria-label="Siguiente"
      >›</button>
    </div>

    <!-- Dots -->
    <div id="lightbox-dots" class="flex gap-2"></div>

  </div>
</div>

<script>
  const lightbox      = document.getElementById('lightbox')!;
  const img           = document.getElementById('lightbox-img') as HTMLImageElement;
  const dotsEl        = document.getElementById('lightbox-dots')!;
  const btnClose      = document.getElementById('lightbox-close')!;
  const btnPrev       = document.getElementById('lightbox-prev')!;
  const btnNext       = document.getElementById('lightbox-next')!;
  const overlay       = document.getElementById('lightbox-overlay')!;

  let imgs: string[] = [];
  let cur = 0;

  function renderDots() {
    dotsEl.innerHTML = '';
    imgs.forEach((_, i) => {
      const d = document.createElement('button');
      d.className = `w-2 h-2 rounded-full transition-colors ${i === cur ? 'bg-brand-blue' : 'bg-brand-border'}`;
      d.setAttribute('aria-label', `Imagen ${i + 1}`);
      d.addEventListener('click', () => goTo(i));
      dotsEl.appendChild(d);
    });
  }

  function goTo(index: number) {
    cur = (index + imgs.length) % imgs.length;
    img.src = imgs[cur];
    // dots
    dotsEl.querySelectorAll('button').forEach((d, i) => {
      d.className = `w-2 h-2 rounded-full transition-colors ${i === cur ? 'bg-brand-blue' : 'bg-brand-border'}`;
    });
    // flechas: solo visibles si hay más de 1 imagen
    const multi = imgs.length > 1;
    btnPrev.classList.toggle('hidden', !multi);
    btnNext.classList.toggle('hidden', !multi);
    btnPrev.classList.toggle('flex', multi);
    btnNext.classList.toggle('flex', multi);
  }

  function open(images: string[]) {
    imgs = images;
    cur = 0;
    renderDots();
    goTo(0);
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function close() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
    img.src = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.lightbox-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const images = JSON.parse(btn.dataset.imagenes ?? '[]') as string[];
      open(images);
    });
  });

  btnClose.addEventListener('click', close);
  overlay.addEventListener('click', close);
  btnPrev.addEventListener('click', () => goTo(cur - 1));
  btnNext.addEventListener('click', () => goTo(cur + 1));

  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape')      close();
    if (e.key === 'ArrowLeft')   goTo(cur - 1);
    if (e.key === 'ArrowRight')  goTo(cur + 1);
  });
</script>
