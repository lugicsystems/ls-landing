---
const features = [
  'Facturación electrónica con ARCA',
  'Control Interno de ventas',
  'Gestión de stock e inventario',
  'Caja y cierre diario',
  'Cuentas corrientes de clientes',
  'Presupuestos y remitos',
  'Cambios de precios masivos',
  'Promociones y combos',
  'Comunicación con balanzas digitales',
  'Lectura y emisión de códigos de barra',
  'Reportes detallados',
  'Multiusuario y multisucursal',
];

const rubros = [
  'Supermercados', 'Drugstores', 'Kioscos', 'Almacenes',
  'Ferreterías', 'Bares y cafeterías', 'Rotiserías',
  'Venta de repuestos', 'Comercios en general',
];

const screenshots = [
  { src: '/images/sfc/01-menu-principal.png', alt: 'Menú principal SFC Legacy' },
  { src: '/images/sfc/02-ventas.png', alt: 'Módulo de ventas y facturación' },
  { src: '/images/sfc/03-cuentas-corrientes.png', alt: 'Cuentas corrientes' },
  { src: '/images/sfc/04-cierre-caja.png', alt: 'Cierre de caja' },
  { src: '/images/sfc/05-inventario.png', alt: 'Inventario y stock' },
  { src: '/images/sfc/06-cambios-precios.png', alt: 'Cambios de precios masivos' },
  { src: '/images/sfc/07-promociones.png', alt: 'Promociones y combos' },
];
---

<section id="productos" class="py-24 bg-brand-mid">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-brand-blue text-sm font-semibold uppercase tracking-widest">
        Productos
      </span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-brand-text">
        SFC Legacy
        <span class="text-brand-blue">— Sistema de Gestión Comercial</span>
      </h2>
      <p class="mt-4 text-brand-muted text-lg max-w-2xl mx-auto">
        Software de gestión integral para comercios. Robusto, probado en campo
        y listo para usar desde el primer día.
      </p>
    </div>

    <!-- Contenido principal -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-16">

      <!-- Features -->
      <div>
        <h3 class="text-brand-text font-semibold text-xl mb-6">
          ¿Qué incluye?
        </h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {features.map(f => (
            <li class="flex items-start gap-2 text-brand-muted text-sm">
              <svg class="w-5 h-5 text-brand-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              {f}
            </li>
          ))}
        </ul>

        <!-- Rubros -->
        <h3 class="text-brand-text font-semibold text-xl mt-10 mb-4">
          ¿Para qué rubros?
        </h3>
        <div class="flex flex-wrap gap-2">
          {rubros.map(r => (
            <span class="px-3 py-1 rounded-full bg-brand-dark border border-brand-border text-brand-muted text-sm">
              {r}
            </span>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="#demo"
            class="px-6 py-3 rounded-md bg-brand-blue text-white font-semibold text-sm hover:bg-blue-500 transition-colors duration-200 text-center"
          >
            Ver demo en video
          </a>
          <a
            href="#contacto"
            class="px-6 py-3 rounded-md border border-brand-border text-brand-text font-semibold text-sm hover:border-brand-blue transition-colors duration-200 text-center"
          >
            Solicitar información
          </a>
        </div>
      </div>

      <!-- Carrusel de screenshots -->
      <div class="relative">
        <div id="carousel" class="overflow-hidden rounded-xl border border-brand-border">
          {screenshots.map((s, i) => (
            <div
              class={`carousel-slide ${i === 0 ? 'block' : 'hidden'}`}
              data-index={i}
            >
              <img
                src={s.src}
                alt={s.alt}
                class="w-full object-cover"
              />
            </div>
          ))}
        </div>

        <!-- Controles -->
        <div class="flex items-center justify-between mt-4">
          <button
            id="prev-btn"
            class="px-4 py-2 rounded-md bg-brand-dark border border-brand-border text-brand-muted hover:text-brand-text hover:border-brand-blue transition-colors duration-200 text-sm"
          >
            ← Anterior
          </button>
          <div id="dots" class="flex gap-2">
            {screenshots.map((_, i) => (
              <button
                class={`dot w-2 h-2 rounded-full transition-colors duration-200 ${i === 0 ? 'bg-brand-blue' : 'bg-brand-border'}`}
                data-index={i}
              />
            ))}
          </div>
          <button
            id="next-btn"
            class="px-4 py-2 rounded-md bg-brand-dark border border-brand-border text-brand-muted hover:text-brand-text hover:border-brand-blue transition-colors duration-200 text-sm"
          >
            Siguiente →
          </button>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  const slides = document.querySelectorAll('.carousel-slide');
  const dots = document.querySelectorAll('.dot');
  let current = 0;

  function goTo(index: number) {
    slides[current].classList.add('hidden');
    slides[current].classList.remove('block');
    dots[current].classList.remove('bg-brand-blue');
    dots[current].classList.add('bg-brand-border');

    current = (index + slides.length) % slides.length;

    slides[current].classList.remove('hidden');
    slides[current].classList.add('block');
    dots[current].classList.add('bg-brand-blue');
    dots[current].classList.remove('bg-brand-border');
  }

  document.getElementById('next-btn')?.addEventListener('click', () => goTo(current + 1));
  document.getElementById('prev-btn')?.addEventListener('click', () => goTo(current - 1));
  dots.forEach(dot => {
    dot.addEventListener('click', () => goTo(Number(dot.getAttribute('data-index'))));
  });
</script>