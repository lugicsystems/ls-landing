---
// Contacto.astro

const WA_BASE    = "https://wa.me/5493512548711?text=";
const WA_LINK    = "https://wa.link/tcc76s";
const MAIL       = "info@lugicsystems.com.ar";
const INSTAGRAM  = "https://instagram.com/lugicsystems";
---

<section id="contacto" class="bg-brand-mid py-20 px-4">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-14">
      <span class="text-brand-blue text-sm font-semibold uppercase tracking-widest">Contacto</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-brand-text mt-2">
        ¿Listo para digitalizar tu negocio?
      </h2>
      <p class="text-brand-muted mt-4 max-w-xl mx-auto">
        Contanos cómo se llama tu negocio y te respondemos por WhatsApp. Sin vueltas.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center max-w-4xl mx-auto">

      <!-- Formulario -->
      <div class="bg-brand-dark border border-brand-border rounded-2xl p-8 flex flex-col gap-6">
        <div class="flex flex-col gap-2">
          <label for="contact-name" class="text-brand-text text-sm font-medium">
            ¿Cómo se llama tu negocio o cómo te llamás?
          </label>
          <input
            id="contact-name"
            type="text"
            placeholder="Ej: Despensa El Trébol / Juan"
            class="bg-brand-mid border border-brand-border rounded-xl px-4 py-3 text-brand-text placeholder-brand-muted focus:outline-none focus:border-brand-blue transition-colors text-sm"
            maxlength="60"
          />
        </div>

        <button
          id="wa-contact-btn"
          class="flex items-center justify-center gap-3 w-full py-4 rounded-xl bg-[#25D366] hover:bg-[#1ebe5d] text-white font-semibold text-base transition-colors duration-200 shadow-lg shadow-[#25D366]/20"
        >
          <!-- WhatsApp icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Contactar por WhatsApp
        </button>

        <p class="text-brand-muted text-xs text-center">
          Te respondemos en minutos · Lunes a Sábado
        </p>
      </div>

      <!-- Canales alternativos -->
      <div class="flex flex-col gap-6">
        <p class="text-brand-muted text-sm">También podés escribirnos por:</p>

        <!-- WhatsApp directo -->
        <a
          href={WA_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-4 rounded-xl border border-brand-border hover:border-[#25D366]/50 hover:bg-[#25D366]/5 transition-colors group"
        >
          <div class="w-11 h-11 rounded-xl bg-[#25D366]/10 border border-[#25D366]/20 flex items-center justify-center shrink-0 group-hover:bg-[#25D366]/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <p class="text-brand-text font-medium text-sm">WhatsApp</p>
            <p class="text-brand-muted text-xs">Chat directo · Respuesta rápida</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-muted ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Mail -->
        <a
          href={`mailto:${MAIL}`}
          class="flex items-center gap-4 p-4 rounded-xl border border-brand-border hover:border-brand-blue/50 hover:bg-brand-blue/5 transition-colors group"
        >
          <div class="w-11 h-11 rounded-xl bg-brand-blue/10 border border-brand-blue/20 flex items-center justify-center shrink-0 group-hover:bg-brand-blue/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-brand-text font-medium text-sm">Email</p>
            <p class="text-brand-muted text-xs">{MAIL}</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-muted ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>

        <!-- Instagram -->
        <a
          href={INSTAGRAM}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-4 p-4 rounded-xl border border-brand-border hover:border-pink-500/50 hover:bg-pink-500/5 transition-colors group"
        >
          <div class="w-11 h-11 rounded-xl bg-pink-500/10 border border-pink-500/20 flex items-center justify-center shrink-0 group-hover:bg-pink-500/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </div>
          <div>
            <p class="text-brand-text font-medium text-sm">Instagram</p>
            <p class="text-brand-muted text-xs">@lugicsystems</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-muted ml-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>

      </div>
    </div>
  </div>
</section>

<script>
  // @ts-nocheck
  const btn   = document.getElementById('wa-contact-btn')!;
  const input = document.getElementById('contact-name') as HTMLInputElement;

  const MSG_BASE = "Hola! 👋 Vengo de la Web de *Lugic Systems* 🌐... Tengo un negocio y necesito más info sobre el Software, Equipamiento y Servicios que ofrecen! 🤝";
  const WA_LINK  = "https://wa.link/tcc76s";

  btn.addEventListener('click', () => {
    const nombre = input.value.trim();
    if (nombre) {
      const msg = `Hola! 👋 Soy ${nombre}. Vengo de la Web de *Lugic Systems* 🌐... Tengo un negocio y necesito más info sobre el Software, Equipamiento y Servicios que ofrecen! 🤝`;
      const url = `https://wa.me/5493512548711?text=${encodeURIComponent(msg)}`;
      if (typeof fbq !== 'undefined') fbq('track', 'Contact');
      window.open(url, '_blank', 'noopener,noreferrer');
    } else {
      if (typeof fbq !== 'undefined') fbq('track', 'Contact');
      window.open(WA_LINK, '_blank', 'noopener,noreferrer');
    }
  });

  // Enter en el input también dispara
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') btn.click();
  });
</script>
