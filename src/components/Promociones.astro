---
// Sección: Promociones vigentes
---

<section id="promociones" class="py-24 bg-brand-mid">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-brand-blue text-sm font-semibold uppercase tracking-widest">
        Promociones
      </span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-brand-text">
        Ofertas vigentes
        <span class="text-brand-blue"> hasta agotar stock</span>
      </h2>
      <p class="mt-4 text-brand-muted text-lg max-w-2xl mx-auto">
        Combos pensados para que tu negocio arranque con todo, desde el primer día.
      </p>
    </div>

    <!-- Promo card -->
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 rounded-2xl overflow-hidden border border-brand-blue shadow-2xl">

        <!-- Imagen -->
        <div class="relative">
          <img
            src="/images/promo-combo-pdv.png"
            alt="Combo Punto de Venta — Lugic Systems"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-transparent to-brand-dark/60 hidden lg:block" />
        </div>

        <!-- Contenido -->
        <div class="bg-brand-dark p-8 flex flex-col justify-center">

          <!-- Badge -->
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide animate-pulse">
              Stock limitado
            </span>
            <span class="border border-brand-blue text-brand-blue text-xs font-semibold px-3 py-1 rounded-full">
              Sin abono mensual
            </span>
          </div>

          <h3 class="text-2xl font-bold text-brand-text mb-2">
            Combo de Locos 🔥
          </h3>
          <p class="text-brand-muted text-sm mb-6">
            Todo listo para usar desde el primer día. Software + equipamiento completo.
          </p>

          <!-- Incluye -->
          <ul class="space-y-2 mb-8">
            {[
              'Software SFC Punto de Venta',
              'Mini PC completa',
              'Lector de código de barras',
              'Ticketera térmica 80mm',
              'Instalación y configuración sin cargo',
            ].map(item => (
              <li class="flex items-center gap-2 text-brand-text text-sm font-medium">
                <svg class="w-4 h-4 text-brand-blue shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

          <!-- Precio -->
          <div class="flex items-end gap-3 mb-8">
            <span class="text-brand-muted line-through text-xl">USD 789</span>
            <span class="text-5xl font-bold text-brand-text">USD 749</span>
          </div>

          <!-- CTA -->
          <a
            href={`https://wa.me/5493512548711?text=${encodeURIComponent('Hola! 👋 Vengo de la web de Lugic Systems. Me interesa la *promo vigente*. ¿Me pueden dar más info?')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full py-3 rounded-md bg-brand-blue text-white font-semibold text-center hover:bg-blue-500 transition-colors duration-200"
          >
            Quiero este combo →
          </a>

        </div>
      </div>
    </div>

    <!-- Más promos futuras -->
    <p class="text-center text-brand-muted text-sm mt-10">
      ¿Necesitás algo diferente?
      <a href="#contacto" class="text-brand-blue hover:underline ml-1">
        Consultanos y armamos un combo a tu medida.
      </a>
    </p>

  </div>
</section>
