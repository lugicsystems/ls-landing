---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description = 'Software y tecnología para negocios inteligentes. SFC Legacy: gestión comercial, facturación ARCA, stock, cuentas corrientes y más. Córdoba, Argentina.',
  ogImage = '/images/og-image.png',
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteURL = 'https://www.lugicsystems.com.ar';
const ogImageAbsolute = `${siteURL}${ogImage}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Lugic Systems" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lugic Systems" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Lugic Systems — Software y Tecnología para Negocios Inteligentes" />
    <meta property="og:locale" content="es_AR" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fuentes -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "ProfessionalService"],
      "name": "Lugic Systems",
      "description": "Software y tecnología para negocios inteligentes. Desarrollo de software de gestión comercial, equipamiento, redes, cámaras de seguridad y energía solar.",
      "url": "https://www.lugicsystems.com.ar",
      "logo": "https://www.lugicsystems.com.ar/images/logo.png",
      "image": "https://www.lugicsystems.com.ar/images/og-image.png",
      "telephone": "+5493512548711",
      "email": "info@lugicsystems.com.ar",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Córdoba",
        "addressRegion": "Córdoba",
        "addressCountry": "AR"
      },
      "areaServed": {
        "@type": "Country",
        "name": "Argentina"
      },
      "sameAs": [
        "https://instagram.com/lugicsystems",
        "https://wa.me/5493512548711"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios Lugic Systems",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Software de Gestión Comercial" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Equipamiento Comercial" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Redes de Datos" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Cámaras de Seguridad" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Energía Solar" } }
        ]
      }
    }
    </script>

    <!-- Meta Pixel -->
    <script>
      // @ts-nocheck
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1114801420407345');
      fbq('track', 'PageView');
    </script>
    <noscript>
      <img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id=1114801420407345&ev=PageView&noscript=1"/>
    </noscript>
    <!-- End Meta Pixel -->
  </head>
  <body class="bg-brand-dark text-brand-text antialiased">
    <slot />

    <!-- Cloudflare Web Analytics -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "0ffe288bffbd4017877134a394376b71"}'></script>
    <!-- End Cloudflare Web Analytics -->

    <!-- Meta Pixel: trackear clicks WhatsApp -->
    <script>
      // @ts-nocheck
      document.addEventListener('click', function(e) {
        const el = e.target.closest('a[href*="wa.me"], a[href*="wa.link"]');
        if (el && typeof fbq !== 'undefined') {
          fbq('track', 'Contact');
        }
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>