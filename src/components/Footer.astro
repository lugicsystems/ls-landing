---
// Footer.astro

const year = new Date().getFullYear();

const navLinks = [
  { label: "Quiénes somos", href: "#quienes-somos" },
  { label: "Qué hacemos",   href: "#que-hacemos" },
  { label: "Productos",     href: "#productos" },
  { label: "Demo",          href: "#demo" },
  { label: "Planes",        href: "#planes" },
  { label: "Promociones",   href: "#promociones" },
  { label: "Testimonios",   href: "#testimonios" },
  { label: "Contacto",      href: "#contacto" },
];

const socials = [
  {
    label: "WhatsApp",
    href: "https://wa.link/tcc76s",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
    color: "hover:text-[#25D366]",
  },
  {
    label: "Instagram",
    href: "https://instagram.com/lugicsystems",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>`,
    color: "hover:text-pink-400",
  },
  {
    label: "Email",
    href: "mailto:info@lugicsystems.com.ar",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    color: "hover:text-brand-blue",
  },
];
---

<footer class="bg-brand-dark border-t border-brand-border">
  <div class="max-w-6xl mx-auto px-4 py-12">

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 mb-10">

      <!-- Logo + tagline -->
      <div class="flex flex-col gap-4">
        <a href="#" aria-label="Lugic Systems — inicio">
          <img src="/images/logo.png" alt="Lugic Systems" class="h-8 w-auto" />
        </a>
        <p class="text-brand-muted text-sm leading-relaxed">
          Software y Tecnología<br />para Negocios Inteligentes.
        </p>
        <!-- Redes -->
        <div class="flex gap-3 mt-1">
          {socials.map((s) => (
            <a
              href={s.href}
              target={s.href.startsWith('mailto') ? undefined : '_blank'}
              rel="noopener noreferrer"
              aria-label={s.label}
              class={`text-brand-muted transition-colors ${s.color}`}
              set:html={s.icon}
            />
          ))}
        </div>
      </div>

      <!-- Navegación -->
      <div class="flex flex-col gap-3">
        <p class="text-brand-text text-sm font-semibold uppercase tracking-widest mb-1">Navegación</p>
        {navLinks.slice(0, 4).map((l) => (
          <a href={l.href} class="text-brand-muted text-sm hover:text-brand-text transition-colors">
            {l.label}
          </a>
        ))}
      </div>

      <div class="flex flex-col gap-3">
        <p class="text-brand-text text-sm font-semibold uppercase tracking-widest mb-1">&nbsp;</p>
        {navLinks.slice(4).map((l) => (
          <a href={l.href} class="text-brand-muted text-sm hover:text-brand-text transition-colors">
            {l.label}
          </a>
        ))}
      </div>

    </div>

    <!-- Divider + copyright -->
    <div class="border-t border-brand-border pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-brand-muted text-xs">
        © {year} Lugic Systems. Todos los derechos reservados.
      </p>
      <p class="text-brand-muted text-xs">
        Córdoba, Argentina · 
        <a href="mailto:info@lugicsystems.com.ar" class="hover:text-brand-text transition-colors">
          info@lugicsystems.com.ar
        </a>
      </p>
    </div>

  </div>
</footer>
