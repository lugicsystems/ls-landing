---
const areas = [
  {
    titulo: 'Software de Gestión',
    descripcion: 'Soluciones listas para usar para comercios de todo tipo: puntos de venta, facturación electrónica ARCA, stock, caja, cuentas corrientes, reportes y más. También desarrollo a medida.',
    icono: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
    </svg>`,
  },
  {
    titulo: 'Equipamiento Comercial',
    descripcion: 'Proveemos e instalamos equipamiento para tu negocio: computadoras, notebooks, mini pc, tickeadoras/comanderas térmicas, lectores de código de barras, balanzas digitales y periféricos.',
    icono: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />
    </svg>`,
  },
  {
    titulo: 'Redes de Datos',
    descripcion: 'Diseño, instalación y configuración de redes cableadas e inalámbricas para empresas. Infraestructura confiable para que tu operación nunca se detenga.',
    icono: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />
    </svg>`,
  },
  {
    titulo: 'Cámaras de Seguridad',
    descripcion: 'Instalación de sistemas de videovigilancia para comercios y empresas. Monitoreo local y remoto, grabación continua y acceso desde cualquier dispositivo.',
    icono: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />
    </svg>`,
  },
  {
    titulo: 'Energía Solar',
    descripcion: 'Instalaciones fotovoltaicas para reducir costos operativos y ganar independencia energética. Soluciones para comercios y empresas de todos los tamaños.',
    icono: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
    </svg>`,
  },
];
---

<section id="que-hacemos" class="py-24 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="text-brand-blue text-sm font-semibold uppercase tracking-widest">
        Qué hacemos
      </span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-brand-text">
        Todo lo que tu negocio necesita,<br />
        <span class="text-brand-blue">en un solo lugar</span>
      </h2>
      <p class="mt-4 text-brand-muted text-lg max-w-2xl mx-auto">
        Desde el software hasta la infraestructura. Somos el partner tecnológico
        que acompaña el crecimiento de tu empresa.
      </p>
    </div>

    <!-- Grid de áreas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {areas.map(area => (
        <div class="bg-brand-mid rounded-xl p-6 border border-brand-border hover:border-brand-blue transition-colors duration-200 group">
          <div class="text-brand-blue mb-4 group-hover:scale-110 transition-transform duration-200" set:html={area.icono} />
          <h3 class="text-brand-text font-semibold text-lg mb-2">{area.titulo}</h3>
          <p class="text-brand-muted text-sm leading-relaxed">{area.descripcion}</p>
        </div>
      ))}
    </div>

  </div>
</section>