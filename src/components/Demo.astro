---

<section id="demo" class="py-24 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-16">
      <span class="text-brand-blue text-sm font-semibold uppercase tracking-widest">Demo</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-brand-text">
        Miralo en acción,<br />
        <span class="text-brand-blue">antes de decidir</span>
      </h2>
      <p class="mt-4 text-brand-muted text-lg max-w-2xl mx-auto">
        Demos cortas y específicas de cada parte del sistema, 
        para que puedas ver exactamente lo que buscás!
      </p>
    </div>

    <!-- Intro -->
    <div class="mb-12">
      <p class="text-center text-brand-muted text-sm uppercase tracking-widest mb-6">Antes de empezar</p>
      <div class="max-w-3xl mx-auto">
        <div class="relative rounded-xl overflow-hidden bg-brand-mid border border-brand-border" style="padding-top: 56.25%;">
          <iframe
            class="absolute inset-0 w-full h-full"
            src={toEmbed(VIDEOS.intro)}
            title="Introducción — SFC Legacy"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <p class="text-center text-brand-muted text-sm mt-3">
          Una presentación rápida antes de entrar al sistema
        </p>
      </div>
    </div>

    <!-- Demo general -->
    <div class="mb-16">
      <p class="text-center text-brand-muted text-sm uppercase tracking-widest mb-6">Demo general</p>
      <div class="max-w-3xl mx-auto">
        <div class="relative rounded-xl overflow-hidden bg-brand-mid border border-brand-border" style="padding-top: 56.25%;">
          <iframe
            class="absolute inset-0 w-full h-full"
            src={VIDEOS.general}
            title="Demo general SFC Legacy — Lugic Systems"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <p class="text-center text-brand-muted text-sm mt-3">
          Recorrido completo del sistema · ~3 minutos
        </p>
      </div>
    </div>

    <!-- Demos por categoría -->
    <div class="mb-12">
      <p class="text-center text-brand-muted text-sm uppercase tracking-widest mb-10">Demos específicas por tema</p>
      <div class="space-y-10">
        {categorias.map(cat => (
          <div>
            <div class="flex items-center gap-2 mb-4">
              <span style={`color: ${cat.color}`} set:html={cat.icono} />
              <h3 class="text-brand-text font-semibold text-lg">{cat.nombre}</h3>
              <div class="flex-1 h-px bg-brand-border ml-2"></div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {cat.demos.map(demo => (
                <button
                  type="button"
                  class="demo-card flex flex-col overflow-hidden rounded-xl border border-brand-border text-left w-full"
                  style={`border-left: 4px solid ${cat.color}`}
                  data-embed={toEmbed(demo.url)}
                  data-titulo={demo.titulo}
                  onclick="abrirDemo(this)"
                >
                  <!-- Thumbnail -->
                  <div class="relative overflow-hidden" style="padding-top: 56.25%;">
                    <img
                      src={toThumb(demo.url)}
                      alt={demo.titulo}
                      class="demo-thumb absolute inset-0 w-full h-full object-cover"
                      loading="lazy"
                    />
                    <!-- Overlay oscuro -->
                    <div class="demo-overlay absolute inset-0" style="background: rgba(0,0,0,0.50);"></div>
                    <!-- Botón play -->
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div
                        class="demo-play w-12 h-12 rounded-full flex items-center justify-center"
                        style={`background-color: ${cat.color}cc`}
                      >
                        <svg class="w-5 h-5 ml-0.5 text-white" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M8 5v14l11-7z"/>
                        </svg>
                      </div>
                    </div>
                    <!-- Badge duración -->
                    <span
                      class="absolute bottom-2 right-2 text-xs font-semibold px-2 py-0.5 rounded-full text-white"
                      style={`background-color: ${cat.color}dd`}
                    >
                      ▶ {demo.duracion}
                    </span>
                  </div>
                  <!-- Título -->
                  <div class="bg-brand-mid px-3 py-2.5">
                    <p class="text-brand-text text-sm font-medium leading-snug">{demo.titulo}</p>
                  </div>
                </button>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Cierre -->
    <div class="mb-16">
      <p class="text-center text-brand-muted text-sm uppercase tracking-widest mb-6">¿Qué sigue?</p>
      <div class="max-w-3xl mx-auto">
        <div class="relative rounded-xl overflow-hidden bg-brand-mid border border-brand-border" style="padding-top: 56.25%;">
          <iframe
            class="absolute inset-0 w-full h-full"
            src={toEmbed(VIDEOS.cierre)}
            title="Cierre — SFC Legacy"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <p class="text-center text-brand-muted text-sm mt-3">
          Ya viste el sistema — esto es lo que podés hacer ahora
        </p>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center pt-8 border-t border-brand-border">
      <p class="text-brand-muted mb-4">¿Preferís que te hagamos una demo en vivo, adaptada a tu negocio?</p>
      <a
        href="#contacto"
        class="inline-block bg-brand-blue hover:bg-blue-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Quiero una demo personalizada
      </a>
    </div>

  </div>
</section>

<!-- Lightbox de video -->
<div id="demo-lightbox" class="demo-lb-overlay" role="dialog" aria-modal="true" aria-label="Reproductor de demo">
  <div class="demo-lb-container">
    <div class="demo-lb-header">
      <p id="demo-lb-titulo" class="demo-lb-titulo"></p>
      <button type="button" class="demo-lb-close" onclick="cerrarDemo()" aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="demo-lb-video">
      <iframe
        id="demo-lb-iframe"
        class="absolute inset-0 w-full h-full"
        src=""
        title="Demo SFC Legacy"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</div>

<script>
  function abrirDemo(btn: HTMLElement) {
    const embed = btn.getAttribute('data-embed') || '';
    const titulo = btn.getAttribute('data-titulo') || '';
    const lb = document.getElementById('demo-lightbox') as HTMLElement;
    const iframe = document.getElementById('demo-lb-iframe') as HTMLIFrameElement;
    const tituloEl = document.getElementById('demo-lb-titulo') as HTMLElement;
    iframe.src = embed + '?autoplay=1&rel=0';
    tituloEl.textContent = titulo;
    lb.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function cerrarDemo() {
    const lb = document.getElementById('demo-lightbox') as HTMLElement;
    const iframe = document.getElementById('demo-lb-iframe') as HTMLIFrameElement;
    lb.classList.remove('active');
    iframe.src = '';
    document.body.style.overflow = '';
  }

  document.getElementById('demo-lightbox')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) cerrarDemo();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') cerrarDemo();
  });

  (window as any).abrirDemo = abrirDemo;
  (window as any).cerrarDemo = cerrarDemo;
</script>

<style>
  /* Cards */
  .demo-card {
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .demo-card:hover {
    filter: brightness(1.08);
  }
  .demo-thumb {
    transition: transform 0.35s ease;
  }
  .demo-card:hover .demo-thumb {
    transform: scale(1.06);
  }
  .demo-overlay {
    transition: background 0.2s ease;
  }
  .demo-card:hover .demo-overlay {
    background: rgba(0,0,0,0.25) !important;
  }
  .demo-play {
    transition: transform 0.2s ease;
  }
  .demo-card:hover .demo-play {
    transform: scale(1.15);
  }

  /* Lightbox */
  .demo-lb-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.85);
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .demo-lb-overlay.active {
    display: flex;
  }
  .demo-lb-container {
    width: 100%;
    max-width: 900px;
    background: #111827;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid #1F2937;
  }
  .demo-lb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #1F2937;
  }
  .demo-lb-titulo {
    color: #F9FAFB;
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .demo-lb-close {
    color: #9CA3AF;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 0.25rem;
    transition: color 0.15s;
    flex-shrink: 0;
  }
  .demo-lb-close:hover {
    color: #F9FAFB;
  }
  .demo-lb-video {
    position: relative;
    padding-top: 56.25%;
    background: #000;
  }
</style>