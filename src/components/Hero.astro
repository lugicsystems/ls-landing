---
// Hero — primera sección visible, por encima del fold
---

<section class="min-h-screen flex flex-col items-center justify-center bg-brand-dark px-4 pt-16 text-center">

  <!-- Logo grande -->
  <img
    src="/images/logo.png"
    alt="Lugic Systems"
    class="w-64 sm:w-80 mb-8"
  />

  <!-- Slogan -->
  <h1 class="text-3xl sm:text-5xl font-bold text-brand-text mb-4 max-w-3xl leading-tight">
    Software y Tecnología para<br />
    <span class="text-brand-blue">Negocios Inteligentes</span>
  </h1>

  <!-- Subtítulo -->
  <p class="text-brand-muted text-lg sm:text-xl mb-10 max-w-xl">
    Soluciones de software, equipamiento, redes y energía solar para empresas que quieren crecer.
  </p>

  <!-- CTAs -->
  <div class="flex flex-col sm:flex-row gap-4">
    <a
      href="#contacto"
      class="px-8 py-3 rounded-md bg-brand-blue text-white font-semibold text-lg hover:bg-blue-500 transition-colors duration-200"
    >
      Contactanos
    </a>
    <a
      href="#que-hacemos"
      class="px-8 py-3 rounded-md border border-brand-border text-brand-text font-semibold text-lg hover:border-brand-blue transition-colors duration-200"
    >
      Conocé más
    </a>
  </div>

</section>