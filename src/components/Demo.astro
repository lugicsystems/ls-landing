---
// Sección: Demo
const videoPresentacion = 'https://www.youtube.com/embed/YUrYPRhclqQ?start=7';
const videoTutorial = 'https://www.youtube.com/watch?v=Qu-5ZnB_K7s';
---

<section id="demo" class="py-24 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-12">
      <span class="text-brand-blue text-sm font-semibold uppercase tracking-widest">
        Demo
      </span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-brand-text">
        Miralo en acción
      </h2>
      <p class="mt-4 text-brand-muted text-lg max-w-2xl mx-auto">
        En 6 minutos vas a ver todo lo que SFC Legacy puede hacer por tu negocio.
        Sin tecnicismos, directo al grano.
      </p>
    </div>

    <!-- Video embed -->
    <div class="max-w-4xl mx-auto">
      <div class="relative rounded-xl overflow-hidden border border-brand-border shadow-2xl"
           style="padding-top: 56.25%;">
        <iframe
          src={videoPresentacion}
          title="SFC Legacy — Presentación del sistema"
          class="absolute inset-0 w-full h-full"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        />
      </div>

      <!-- Links secundarios -->
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-brand-muted text-sm">
          ¿Querés profundizar más?
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={videoTutorial}
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 rounded-md border border-brand-border text-brand-text font-semibold text-sm hover:border-brand-blue transition-colors duration-200 text-center"
          >
            Ver tutorial completo (40 min) →
          </a>
          <a
            href="#contacto"
            class="px-6 py-3 rounded-md bg-brand-blue text-white font-semibold text-sm hover:bg-blue-500 transition-colors duration-200 text-center"
          >
            Quiero una demo personalizada
          </a>
        </div>
      </div>
    </div>

  </div>
</section>
