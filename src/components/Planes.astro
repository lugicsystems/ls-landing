---
const WA = "5493512548711";

const planesComercio = [
  {
    nombre: 'SFC Punto',
    precio: 229,
    mensual: 19,
    entregaMensual: 99,
    descripcion: 'Punto de venta completo para comercios.',
    destacado: false,
    features: [
      'Control Interno de Ventas',
      'Caja diaria por turnos',
      'Multiusuario',
      'Listas de precio',
      'Combos y promociones',
      'Informes de ventas',
    ],
  },
  {
    nombre: 'SFC Gestión',
    precio: 299,
    mensual: 25,
    entregaMensual: 99,
    descripcion: 'Gestión integral + punto de venta.',
    destacado: false,
    features: [
      'Todo lo de SFC Punto',
      'Control completo de stock',
      'Inventarios',
      'Ingreso de compras',
      'Egresos de mercadería',
    ],
  },
  {
    nombre: 'SFC Gestión Plus',
    precio: 329,
    mensual: 35,
    entregaMensual: 99,
    descripcion: 'El más completo para gestión y facturación.',
    destacado: true,
    features: [
      'Todo lo de SFC Gestión',
      'Facturación electrónica ARCA',
      'Conexión directa con ARCA',
      'Control interno + fiscal',
    ],
  },
  {
    nombre: 'SFC Gestión Premium',
    precio: 439,
    mensual: 35,
    entregaMensual: 199,
    descripcion: 'Software completo + equipamiento incluido.',
    destacado: false,
    features: [
      'Todo lo de SFC Gestión Plus',
      'Tickeadora térmica 80mm USB+LAN',
      'Lector de códigos de barra láser',
      'Instalación y configuración incluida',
    ],
  },
];

const planesGastronomia = [
  {
    nombre: 'SFC Gastro Simple',
    precio: 349,
    mensual: 39,
    entregaMensual: 99,
    descripcion: 'Punto de venta gastronómico completo.',
    destacado: false,
    features: [
      'Control Interno de Ventas',
      'Facturación Electrónica (ARCA)',
      'Stock y caja diaria',
      'Multiusuario y listas de precio',
      'Combos y promociones',
      'Manejo de mesas y mozos',
      'Zonas/sectores con comanderas',
      'Pedidos en suspenso / Take Away',
      'Detalles en ticket y comanda',
    ],
  },
  {
    nombre: 'SFC Gastro Plus',
    precio: 429,
    mensual: 39,
    entregaMensual: 199,
    descripcion: 'Todo lo anterior + comandera térmica incluida.',
    destacado: true,
    features: [
      'Todo lo de SFC Gastro Simple',
      'Comandera térmica USB+LAN 80mm',
      'Instalación y configuración incluida',
    ],
  },
];
---

<section id="planes" class="py-24 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-6">
      <span class="text-brand-blue text-sm font-semibold uppercase tracking-widest">Planes y precios</span>
      <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-brand-text">
        Elegí el plan que se adapta
        <span class="text-brand-blue"> a tu negocio</span>
      </h2>
      <p class="mt-4 text-brand-muted text-lg max-w-2xl mx-auto">
        Pago único sin abonos mensuales — o modalidad mensual sin contrato mínimo.
        Instalación, configuración y capacitación <strong class="text-brand-text">sin cargo</strong>.
      </p>
    </div>

    <div class="flex justify-center mb-12">
      <div class="flex bg-brand-mid border border-brand-border rounded-lg p-1 gap-1">
        <button id="btn-unica" class="modalidad-btn px-5 py-2 rounded-md text-sm font-medium transition-colors duration-200 bg-brand-blue text-white">
          Pago único
        </button>
        <button id="btn-mensual" class="modalidad-btn px-5 py-2 rounded-md text-sm font-medium transition-colors duration-200 text-brand-muted hover:text-brand-text">
          Mensual
        </button>
      </div>
    </div>

    <!-- Comercios generales -->
    <h3 class="text-brand-text font-semibold text-xl mb-6 text-center">Comercios generales</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      {planesComercio.map(plan => (
        <div class={`relative rounded-xl border p-6 flex flex-col ${plan.destacado ? 'border-brand-blue bg-brand-mid' : 'border-brand-border bg-brand-mid'}`}>
          {plan.destacado && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-brand-blue text-white text-xs font-semibold px-3 py-1 rounded-full">Más elegido</span>
            </div>
          )}
          <div class="mb-4">
            <h4 class="text-brand-text font-bold text-lg">{plan.nombre}</h4>
            <p class="text-brand-muted text-sm mt-1">{plan.descripcion}</p>
          </div>
          <div class="precio-unico mb-6">
            <span class="text-3xl font-bold text-brand-text">USD {plan.precio}</span>
            <span class="text-brand-muted text-sm ml-1">pago único</span>
          </div>
          <div class="precio-mensual hidden mb-6">
            <span class="text-brand-muted text-sm block">USD {plan.entregaMensual} entrega inicial +</span>
            <span class="text-3xl font-bold text-brand-text">USD {plan.mensual}</span>
            <span class="text-brand-muted text-sm ml-1">/mes</span>
          </div>
          <ul class="space-y-2 flex-1 mb-6">
            {plan.features.map(f => (
              <li class="flex items-start gap-2 text-brand-muted text-sm">
                <svg class="w-4 h-4 text-brand-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a
            href="#"
            data-plan={plan.nombre}
            data-precio-unico={plan.precio}
            data-precio-mensual={plan.mensual}
            data-entrega={plan.entregaMensual}
            class={`wa-plan-btn w-full py-2.5 rounded-md text-sm font-semibold text-center transition-colors duration-200 ${plan.destacado ? 'bg-brand-blue text-white hover:bg-blue-500' : 'border border-brand-border text-brand-text hover:border-brand-blue'}`}
          >
            Consultar
          </a>
        </div>
      ))}
    </div>

    <!-- Gastronomía -->
    <h3 class="text-brand-text font-semibold text-xl mb-6 text-center">
      Rubro gastronómico
      <span class="ml-2 text-xs font-normal text-brand-blue border border-brand-blue px-2 py-0.5 rounded-full">
        Bar · Restaurante · Rotisería
      </span>
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto mb-12">
      {planesGastronomia.map(plan => (
        <div class={`relative rounded-xl border p-6 flex flex-col ${plan.destacado ? 'border-brand-blue bg-brand-mid' : 'border-brand-border bg-brand-mid'}`}>
          {plan.destacado && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="bg-brand-blue text-white text-xs font-semibold px-3 py-1 rounded-full">Más elegido</span>
            </div>
          )}
          <div class="mb-4">
            <h4 class="text-brand-text font-bold text-lg">{plan.nombre}</h4>
            <p class="text-brand-muted text-sm mt-1">{plan.descripcion}</p>
          </div>
          <div class="precio-unico mb-6">
            <span class="text-3xl font-bold text-brand-text">USD {plan.precio}</span>
            <span class="text-brand-muted text-sm ml-1">pago único</span>
          </div>
          <div class="precio-mensual hidden mb-6">
            <span class="text-brand-muted text-sm block">USD {plan.entregaMensual} entrega inicial +</span>
            <span class="text-3xl font-bold text-brand-text">USD {plan.mensual}</span>
            <span class="text-brand-muted text-sm ml-1">/mes</span>
          </div>
          <ul class="space-y-2 flex-1 mb-6">
            {plan.features.map(f => (
              <li class="flex items-start gap-2 text-brand-muted text-sm">
                <svg class="w-4 h-4 text-brand-blue shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a
            href="#"
            data-plan={plan.nombre}
            data-precio-unico={plan.precio}
            data-precio-mensual={plan.mensual}
            data-entrega={plan.entregaMensual}
            class={`wa-plan-btn w-full py-2.5 rounded-md text-sm font-semibold text-center transition-colors duration-200 ${plan.destacado ? 'bg-brand-blue text-white hover:bg-blue-500' : 'border border-brand-border text-brand-text hover:border-brand-blue'}`}
          >
            Consultar
          </a>
        </div>
      ))}
    </div>

    <p class="text-center text-brand-muted text-xs max-w-xl mx-auto">
      Precios por licencia instalada en un puesto de trabajo (PC/Notebook).
      Instalación, configuración y capacitación sin cargo en Córdoba Capital.
      Envíos y soporte remoto a todo el país.
    </p>

  </div>
</section>

<script>
  const WA = "5493512548711";
  let modalidadActual: 'unica' | 'mensual' = 'unica';

  const btnUnica = document.getElementById('btn-unica');
  const btnMensual = document.getElementById('btn-mensual');
  const preciosUnicos = document.querySelectorAll('.precio-unico');
  const preciosMensuales = document.querySelectorAll('.precio-mensual');

  function setModalidad(modo: 'unica' | 'mensual') {
    modalidadActual = modo;
    if (modo === 'unica') {
      preciosUnicos.forEach(el => el.classList.remove('hidden'));
      preciosMensuales.forEach(el => el.classList.add('hidden'));
      btnUnica?.classList.add('bg-brand-blue', 'text-white');
      btnUnica?.classList.remove('text-brand-muted');
      btnMensual?.classList.remove('bg-brand-blue', 'text-white');
      btnMensual?.classList.add('text-brand-muted');
    } else {
      preciosUnicos.forEach(el => el.classList.add('hidden'));
      preciosMensuales.forEach(el => el.classList.remove('hidden'));
      btnMensual?.classList.add('bg-brand-blue', 'text-white');
      btnMensual?.classList.remove('text-brand-muted');
      btnUnica?.classList.remove('bg-brand-blue', 'text-white');
      btnUnica?.classList.add('text-brand-muted');
    }
  }

  btnUnica?.addEventListener('click', () => setModalidad('unica'));
  btnMensual?.addEventListener('click', () => setModalidad('mensual'));

  // Botones Consultar — mensaje dinámico según modalidad activa
  document.querySelectorAll('.wa-plan-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const el = e.currentTarget as HTMLElement;
      const nombre = el.dataset.plan ?? '';
      const precioUnico = el.dataset.precioUnico ?? '';
      const precioMensual = el.dataset.precioMensual ?? '';
      const entrega = el.dataset.entrega ?? '';

      let msg = '';
      if (modalidadActual === 'unica') {
        msg = `Hola! 👋 Vengo de la web de Lugic Systems. Me interesa el plan *${nombre}* (USD ${precioUnico} pago único). ¿Me pueden dar más info?`;
      } else {
        msg = `Hola! 👋 Vengo de la web de Lugic Systems. Me interesa el plan *${nombre}* en modalidad mensual (USD ${entrega} entrega + USD ${precioMensual}/mes). ¿Me pueden dar más info?`;
      }

      window.open(`https://wa.me/${WA}?text=${encodeURIComponent(msg)}`, '_blank');
    });
  });
</script>