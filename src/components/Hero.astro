---
---

<section id="inicio" class="relative min-h-[85vh] flex flex-col items-center justify-center text-center px-4 py-24 overflow-hidden">

  <!-- Glow de fondo -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full"
      style="background: radial-gradient(ellipse at center, rgba(45,107,228,0.10) 0%, transparent 70%);">
    </div>
  </div>

  <!-- Contenido -->
  <div class="relative z-10 flex flex-col items-center gap-6 max-w-2xl mx-auto">
    <img
      src="/images/logo.png"
      alt="Lugic Systems"
      class="w-48 sm:w-64"
      loading="eager"
    />
    <h1 class="text-3xl sm:text-5xl font-bold leading-tight">
      Software y Tecnología para<br/>
      <span class="text-brand-blue">Negocios Inteligentes</span>
    </h1>
    <p class="text-brand-muted text-lg sm:text-xl max-w-xl">
      Soluciones de software, equipamiento, redes y energía solar para empresas que quieren crecer.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 mt-2">
      <a
        href="#contacto"
        class="bg-brand-blue hover:bg-blue-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Contactanos
      </a>
      <a
        href="#quienes-somos"
        class="border border-brand-border hover:border-brand-blue text-brand-text font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Conocé más
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-brand-muted opacity-60">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>

</section>